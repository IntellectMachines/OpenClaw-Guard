# Environment Variables for Molt Guard
# Copy this file to .env and fill in your values

# =============================================================================
# GUARD SERVER CONFIGURATION
# =============================================================================

# JWT secret for signing Moltbook tokens (generate a secure random string)
MOLT_GUARD_JWT_SECRET=your-secure-jwt-secret-here

# API key for authenticating SDK with Guard server
MOLT_GUARD_API_KEY=your-api-key-here

# Guard server port
MOLT_GUARD_PORT=3001

# =============================================================================
# AWS CONFIGURATION
# =============================================================================

# AWS credentials for the Guard to assume roles
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# Role ARN that the Guard will assume to vend temporary credentials
MOLT_GUARD_AWS_ROLE_ARN=arn:aws:iam::123456789012:role/MoltGuardAgentRole

# =============================================================================
# STRIPE CONFIGURATION
# =============================================================================

# Stripe API keys
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# =============================================================================
# MOLTBOOK CONFIGURATION
# =============================================================================

# Moltbook API credentials
MOLTBOOK_API_KEY=your-moltbook-api-key
MOLTBOOK_APP_ID=your-moltbook-app-id

# =============================================================================
# OPTIONAL: EXTERNAL SERVICES
# =============================================================================

# Content moderation service (if using external)
# CONTENT_MODERATION_API_KEY=your-moderation-api-key

# Audit log destination
# AUDIT_LOG_ENDPOINT=https://your-audit-service.com/logs
